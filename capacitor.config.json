{
  "appId": "com.appdoula.nalin",
  "appName": "Doula Nalin Nazareth",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": ["*.trycloudflare.com", "*.youtube.com", "wa.me", "*.videodelivery.net", "*.cloudflarestream.com"]
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#FBF7F4",
      "showSpinner": false
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "appReadyTimeout": 30000
    }
  }
}
